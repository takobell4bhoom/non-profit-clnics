---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import donateImg from '../assets/donate.jpg';
---
<Layout>
  <!-- Hero Section with Community Imagery -->
  <section class="max-w-7xl mx-auto py-24 px-6 grid lg:grid-cols-2 gap-16 items-center">
    <div class="order-2 lg:order-1 relative">
      <div class="absolute inset-0 bg-slate-200 rounded-[2.5rem] rotate-3 scale-105 -z-10"></div>
      
      <!-- Optimized Local Asset -->
      <Image 
        src={donateImg} 
        alt="Charity and Donation Drop Box" 
        class="rounded-[2.5rem] shadow-2xl w-full h-[500px] object-cover border-4 border-white"
      />
      
    </div>

    <div class="order-1 lg:order-2">
      <h2 class="text-teal-600 font-bold tracking-widest uppercase text-sm mb-3">Support Our Clinic</h2>
      <h1 class="text-5xl font-extrabold text-slate-900 mb-6">Invest in the health of East Tampa.</h1>
      <p class="text-xl text-slate-600 leading-relaxed mb-8">
        Our ability to provide free services depends entirely on generous donations from people like you. All donations are tax-deductible and directly support clinic operations, medical supplies, and educational resources.
      </p>
    </div>
  </section>
    
  <!-- The Campaign Section -->
  <section class="bg-slate-50 py-24 px-6 border-t border-slate-200">
    <div class="max-w-6xl mx-auto">
      <div class="bg-slate-950 p-12 md:p-16 rounded-[2.5rem] text-white shadow-2xl relative overflow-hidden grid md:grid-cols-2 gap-16 items-center">
        <!-- Decorative Background elements -->
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-teal-500 rounded-full mix-blend-overlay filter blur-[120px] opacity-40"></div>
        <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-blue-600 rounded-full mix-blend-overlay filter blur-[120px] opacity-20"></div>
        
        <div class="relative z-10">
          <div class="inline-block bg-teal-500/20 text-teal-300 font-bold px-4 py-1.5 rounded-full text-sm mb-6 uppercase tracking-wider border border-teal-500/30">Annual Fund Drive</div>
          <h3 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">A Thousand Points of Light</h3>
          <p class="text-slate-300 mb-6 text-lg leading-relaxed">
            George Bush used the phrase "A Thousand Points of Light" to inspire individual contributions to society. Our aim is to be those points of light shining brightly throughout East Tampa.
          </p>
          <p class="text-slate-300 font-medium text-lg border-l-4 border-teal-500 pl-4 bg-white/5 p-4 rounded-r-xl">
            Each <span class="text-teal-400 font-bold text-xl">$10.00</span> contribution represents one point of light. We need 1,000 points of light to balance our $10,000 budget.
          </p>
        </div>
        
        <div class="relative z-10 bg-white/10 p-10 rounded-3xl backdrop-blur-md border border-white/20 text-center shadow-2xl">
          <div class="text-7xl font-extrabold text-white mb-2 tracking-tighter">$10</div>
          <p class="text-teal-300 font-bold mb-10 uppercase tracking-widest text-sm">Monthly Contribution</p>
          <button class="w-full bg-teal-500 hover:bg-teal-400 text-slate-950 font-extrabold text-lg py-5 rounded-2xl shadow-[0_0_40px_rgba(20,184,166,0.4)] transition-all hover:-translate-y-1 hover:shadow-[0_0_60px_rgba(20,184,166,0.6)]">
            Become a Point of Light
          </button>
          <p class="text-slate-400 text-sm mt-6 flex items-center justify-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
            Secure payments processed via Stripe.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>