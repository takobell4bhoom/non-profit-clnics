---
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <!-- Hero Section with Warm Medical Imagery -->
  <section class="relative bg-white pt-20 pb-24 lg:pt-32 lg:pb-32 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
      
      <!-- Text Content -->
      <div class="max-w-2xl relative z-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-teal-50 border border-teal-100 text-teal-700 text-sm font-bold mb-6">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-teal-500"></span>
          </span>
          Accepting New Patients in Hillsborough County
        </div>
        <h1 class="text-5xl lg:text-7xl font-extrabold text-slate-900 tracking-tight leading-[1.1] mb-6">
          Compassionate care, <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-600 to-emerald-500">completely free.</span>
        </h1>
        <p class="text-lg text-slate-600 leading-relaxed mb-10 font-medium">
          As East Tampa's first free clinic, we believe healthcare is a right, not a privilege. We provide high-quality primary care, diabetes management, and health education to our uninsured neighbors.
        </p>
        <div class="flex flex-wrap gap-4">
  <a href="/portal" class="bg-teal-600 hover:bg-teal-700 text-white px-8 py-3.5 rounded-full shadow-lg shadow-teal-600/20 transition-all hover:-translate-y-0.5 font-bold text-lg inline-flex items-center justify-center">
    Schedule a Visit
  </a>
          <a href="/about" class="bg-white border-2 border-slate-200 hover:border-slate-300 text-slate-700 px-8 py-3.5 rounded-full transition-all font-bold text-lg">
            Our Mission
          </a>
        </div>
      </div>

      <!-- Image & Hours Bento Grid -->
      <div class="relative lg:ml-10">
        <!-- Main Hero Image -->
        <div class="relative rounded-[2rem] overflow-hidden shadow-2xl border-4 border-white z-10 aspect-[4/3] lg:aspect-[3/4]">
          <img 
            src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=80&w=2000&auto=format&fit=crop" 
            alt="Doctor smiling and consulting with a patient" 
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent"></div>
          <div class="absolute bottom-6 left-6 right-6 text-white">
            <p class="font-bold text-lg">Dr. Antoinette Lloyd</p>
            <p class="text-slate-200 text-sm">Medical Director & Volunteer</p>
          </div>
        </div>

        <!-- Operating Hours Card (Responsive Fix) -->
        <div class="relative mt-6 md:mt-0 md:absolute md:-bottom-10 md:-left-10 lg:-left-20 bg-white p-6 rounded-3xl shadow-xl border border-slate-100 w-full md:w-[280px] z-20">
          <div class="flex items-center justify-between border-b border-slate-100 pb-4 mb-4">
            <h3 class="font-extrabold text-slate-900">Clinic Hours</h3>
            <div class="bg-teal-50 text-teal-700 text-[10px] font-bold px-2 py-1 rounded uppercase">Walk-ins</div>
          </div>
          <ul class="space-y-3 text-sm">
            <li class="flex justify-between items-center"><span class="font-semibold text-slate-600">Mon - Wed</span> <span class="text-slate-900 font-bold">12pm - 5pm</span></li>
            <li class="flex justify-between items-center"><span class="font-semibold text-slate-600">Thursday</span> <span class="text-red-500 font-bold">CLOSED</span></li>
            <li class="flex justify-between items-center"><span class="font-semibold text-slate-600">Friday</span> <span class="text-slate-900 font-bold">9am - 12pm</span></li>
          </ul>
        </div>
      </div>
      
    </div>
  </section>

  <!-- How It Works / Patient Journey -->
  <section class="bg-slate-50 py-24 px-6 border-y border-slate-200">
    <div class="max-w-7xl mx-auto">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-teal-600 font-bold tracking-widest uppercase text-sm mb-3">Your Path to Care</h2>
        <h3 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4">Getting help shouldn't be complicated.</h3>
        <p class="text-slate-600 text-lg">We've streamlined our process to ensure you get the medical attention you need without the administrative headache.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 relative">
        <div class="hidden md:block absolute top-12 left-[15%] right-[15%] h-0.5 bg-slate-200 -z-10"></div>
        
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 text-center relative">
          <div class="w-16 h-16 bg-teal-600 text-white rounded-full flex items-center justify-center font-bold text-2xl mx-auto mb-6 shadow-lg shadow-teal-600/30 border-4 border-white">1</div>
          <h4 class="text-xl font-bold text-slate-900 mb-3">Check Eligibility</h4>
          <p class="text-slate-600 leading-relaxed">Ensure you reside in Hillsborough County and are currently without private insurance, Medicaid, or Medicare.</p>
        </div>

        <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 text-center relative">
          <div class="w-16 h-16 bg-teal-600 text-white rounded-full flex items-center justify-center font-bold text-2xl mx-auto mb-6 shadow-lg shadow-teal-600/30 border-4 border-white">2</div>
          <h4 class="text-xl font-bold text-slate-900 mb-3">Walk-in or Call</h4>
          <p class="text-slate-600 leading-relaxed">Visit us during our operating hours, or give us a call at (813) 238-6000 to speak with our volunteer staff.</p>
        </div>

        <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 text-center relative">
          <div class="w-16 h-16 bg-teal-600 text-white rounded-full flex items-center justify-center font-bold text-2xl mx-auto mb-6 shadow-lg shadow-teal-600/30 border-4 border-white">3</div>
          <h4 class="text-xl font-bold text-slate-900 mb-3">Receive Care</h4>
          <p class="text-slate-600 leading-relaxed">Meet with our certified physicians and nurses for diagnosis, treatment, and long-term health education.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact & Community Section -->
  <section class="relative py-24 px-6 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src="https://images.unsplash.com/photo-1582213782179-e0d53f98f2ca?q=80&w=2000&auto=format&fit=crop" alt="Diverse hands stacked together" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-slate-900/80 mix-blend-multiply"></div>
    </div>
    
    <div class="max-w-7xl mx-auto relative z-10">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-6">Bridging the Healthcare Gap in East Tampa</h2>
        <p class="text-slate-300 text-lg leading-relaxed">
          Within the 33604, 33610 and 33612 zip codes, the need for accessible healthcare is critical. We rely on community support to address this disparity.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 text-center">
        <div class="bg-white/10 backdrop-blur-md p-8 rounded-3xl border border-white/20">
          <h4 class="text-5xl font-extrabold text-teal-400 mb-2">40%</h4>
          <p class="text-slate-200 font-medium">Of our local population has no health insurance coverage.</p>
        </div>
        <div class="bg-white/10 backdrop-blur-md p-8 rounded-3xl border border-white/20">
          <h4 class="text-5xl font-extrabold text-teal-400 mb-2">25%</h4>
          <p class="text-slate-200 font-medium">Live below the poverty level and urgently need our services.</p>
        </div>
        <div class="bg-white/10 backdrop-blur-md p-8 rounded-3xl border border-white/20">
          <h4 class="text-5xl font-extrabold text-teal-400 mb-2">100%</h4>
          <p class="text-slate-200 font-medium">Free healthcare provided to those who qualify, no strings attached.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- EHR & Telemedicine Foundation -->
  <section class="bg-white py-24 px-6 text-slate-900">
    <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <div class="order-2 lg:order-1 bg-slate-50 p-8 md:p-12 rounded-[2rem] border border-slate-200 shadow-inner">
        <div class="bg-white rounded-xl shadow-sm border border-slate-100 p-6 mb-4">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-teal-100 rounded-full flex items-center justify-center text-teal-600 font-bold">14</div>
            <div>
              <div class="h-4 w-32 bg-slate-200 rounded mb-2"></div>
              <div class="h-3 w-20 bg-slate-100 rounded"></div>
            </div>
          </div>
          <div class="space-y-2">
            <div class="h-10 w-full bg-slate-50 rounded border border-slate-100"></div>
            <div class="h-10 w-full bg-slate-50 rounded border border-slate-100"></div>
          </div>
        </div>
        <div class="text-center text-sm font-bold text-slate-400 uppercase tracking-widest">System Architecture Phase</div>
      </div>

      <div class="order-1 lg:order-2">
        <h2 class="text-teal-600 font-bold tracking-widest uppercase text-sm mb-3">Future Infrastructure</h2>
        <h3 class="text-4xl font-extrabold mb-6 tracking-tight text-slate-900">Modernizing Patient Access</h3>
        <p class="text-lg text-slate-600 leading-relaxed mb-8">
          We are currently upgrading our digital infrastructure. Soon, patients will be able to utilize our new, robust Patient Portal to schedule appointments, manage their health records, and connect with our staff seamlessly.
        </p>
        <ul class="space-y-4 mb-8 font-medium text-slate-700">
          <li class="flex items-center gap-3"><svg class="w-6 h-6 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Streamlined Online Scheduling</li>
          <li class="flex items-center gap-3"><svg class="w-6 h-6 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Secure, HIPAA-Compliant Data</li>
          <li class="flex items-center gap-3"><svg class="w-6 h-6 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg> Faster Check-in Processes</li>
        </ul>
      </div>
    </div>
  </section>
</Layout>