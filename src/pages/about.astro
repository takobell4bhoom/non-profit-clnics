---
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <section class="bg-slate-50 py-24 px-6 border-b border-slate-200">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-teal-600 font-bold tracking-widest uppercase text-sm mb-3">About Us</h2>
      <h1 class="text-5xl font-extrabold text-slate-900 mb-6">Our Mission & Vision</h1>
      <p class="text-xl text-slate-600 leading-relaxed font-medium">
        The mission of the Calvary Community Clinic is to provide FREE healthcare and health education services to the uninsured, underserved and working poor individuals and families of Hillsborough County.
      </p>
    </div>
  </section>
  
  <section class="max-w-7xl mx-auto py-24 px-6 grid lg:grid-cols-2 gap-16 items-center">
    <div>
      <h2 class="text-3xl font-bold text-slate-900 mb-6">Our History & Impact</h2>
      <p class="text-slate-600 leading-relaxed mb-6 text-lg">
        In response to the growing uninsured population in the East Tampa community, Mount Calvary SDA Church established the Calvary Community Clinic. Our goal is to promote holistic wellness and decrease healthcare disparity.
      </p>
      <p class="text-slate-600 leading-relaxed text-lg">
        Within the 33604, 33610 and 33612 zip codes, 40% of the population has no health insurance coverage and 25% live below the poverty level. We exist to provide quality, compassionate health care to address this critical need.
      </p>
    </div>
    
    <!-- Contextual Image Addition -->
    <div class="relative">
      <div class="absolute inset-0 bg-teal-600 rounded-3xl translate-x-4 translate-y-4 -z-10"></div>
      <img 
        src="https://images.unsplash.com/photo-1551076805-e1869033e561?q=80&w=1600&auto=format&fit=crop" 
        alt="Healthcare professional comforting a patient" 
        class="rounded-3xl shadow-xl w-full h-[400px] object-cover"
      />
    </div>
  </section>

  <!-- Board of Directors -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h3 class="text-3xl font-bold text-slate-900 mb-4">Board of Directors</h3>
        <p class="text-slate-600">The dedicated leadership driving our mission forward.</p>
      </div>
      
      <div class="grid sm:grid-cols-2 gap-6">
        <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100 flex items-center gap-5">
          <div class="w-14 h-14 bg-teal-100 text-teal-700 rounded-full flex items-center justify-center font-bold text-xl">PV</div>
          <div><p class="font-bold text-slate-900 text-lg">Dr. Patrick Vincent</p><p class="text-slate-500 text-sm font-medium">Chairman</p></div>
        </div>
        <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100 flex items-center gap-5">
          <div class="w-14 h-14 bg-teal-100 text-teal-700 rounded-full flex items-center justify-center font-bold text-xl">AL</div>
          <div><p class="font-bold text-slate-900 text-lg">Dr. Antoinette Lloyd</p><p class="text-slate-500 text-sm font-medium">Medical Director</p></div>
        </div>
        <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100 flex items-center gap-5">
          <div class="w-14 h-14 bg-teal-100 text-teal-700 rounded-full flex items-center justify-center font-bold text-xl">MA</div>
          <div><p class="font-bold text-slate-900 text-lg">Marcellina Adonis</p><p class="text-slate-500 text-sm font-medium">Secretary</p></div>
        </div>
        <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100 flex items-center gap-5">
          <div class="w-14 h-14 bg-teal-100 text-teal-700 rounded-full flex items-center justify-center font-bold text-xl">AF</div>
          <div><p class="font-bold text-slate-900 text-lg">Annette Forde</p><p class="text-slate-500 text-sm font-medium">Treasurer</p></div>
        </div>
      </div>
    </div>
  </section>
</Layout>