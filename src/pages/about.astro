---
import Layout from '../layouts/Layout.astro';

const officers = [
  { name: "Hugh Percy", role: "Chairman", initials: "HP" },
  { name: "Albert Coleman", role: "Vice Chairman", initials: "AC" },
  { name: "Dr. Ann Marie Weekes", role: "Medical Director", initials: "AW" },
  { name: "Dr. Darnett Nickle", role: "Executive Director", initials: "DN" },
  { name: "Darlene Chisolm", role: "Secretary", initials: "DC" },
  { name: "Nathniel Mattox", role: "Treasurer", initials: "NM" },
];

const directors = [
  { name: "Rosa Cambridge", role: "Director", initials: "RC" },
  { name: "Brenda Greenway", role: "Director", initials: "BG" },
  { name: "Cheryle Kenneth-Jenkins", role: "Director", initials: "CJ" },
  { name: "John Richardson", role: "Director", initials: "JR" },
  { name: "Rev. Essie Sims", role: "Director", initials: "ES" },
  { name: "Dr. Patrick Vincent", role: "Director", initials: "PV" },
];
---
<Layout>
  <section class="bg-slate-50 py-24 px-6 border-b border-slate-200">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-teal-600 font-bold tracking-widest uppercase text-sm mb-3">About</h2>
      <h1 class="text-5xl font-extrabold text-slate-900 mb-6">Our History & Mission</h1>
      <p class="text-xl text-slate-600 leading-relaxed font-medium">
        Birthed out of a compassionate vision by members of the Mount Calvary SDA Church in 2014, Calvary Community Clinic, Inc. was established to address a critical healthcare gap in the East Tampa community. Today, operating as an independent, community-governed free clinic, we remain dedicated to serving our neighbors with quality, compassionate care.
      </p>
    </div>
  </section>
  
  <section class="max-w-7xl mx-auto py-24 px-6 grid lg:grid-cols-2 gap-16 items-center">
    <div>
      <h2 class="text-3xl font-bold text-slate-900 mb-6">The Need in Our Community</h2>
      <p class="text-slate-600 leading-relaxed mb-6 text-lg">
        Within the 33604, 33610, and 33612 zip codes, the realities of our neighbors include:
      </p>
      <ul class="space-y-4 mb-8">
        <li class="flex items-center gap-3 text-lg text-slate-700 font-medium">
          <svg class="w-6 h-6 text-teal-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          40% of the population has no health insurance coverage.
        </li>
        <li class="flex items-center gap-3 text-lg text-slate-700 font-medium">
          <svg class="w-6 h-6 text-teal-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          25% of residents live below the federal poverty level.
        </li>
      </ul>
      <p class="text-slate-600 leading-relaxed text-lg font-medium p-6 bg-teal-50 border-l-4 border-teal-600 rounded-r-xl">
        Calvary Community Clinic bridges this gap by providing essential healthcare services for the underprivileged, uninsured, unemployed, and underserved segments of our community.
      </p>
    </div>
    
    <div class="relative">
      <div class="absolute inset-0 bg-teal-600 rounded-3xl translate-x-4 translate-y-4 -z-10"></div>
      <img 
        src="https://images.unsplash.com/photo-1551076805-e1869033e561?q=80&w=1600&auto=format&fit=crop" 
        alt="Healthcare professional comforting a patient" 
        class="rounded-3xl shadow-xl w-full h-[400px] object-cover"
      />
    </div>
  </section>

  <!-- Expanded Board of Directors -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h3 class="text-3xl font-extrabold text-slate-900 mb-4">Meet The Team</h3>
        <p class="text-lg text-slate-600">The dedicated leadership driving our mission forward.</p>
      </div>
      
      <div class="mb-12">
        <h4 class="text-xl font-bold text-slate-800 border-b border-slate-200 pb-3 mb-8">Officers</h4>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {officers.map(officer => (
            <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100 flex items-center gap-5 hover:shadow-md transition-shadow">
              <div class="w-14 h-14 bg-teal-100 text-teal-700 rounded-full flex items-center justify-center font-bold text-xl shrink-0">{officer.initials}</div>
              <div>
                <p class="font-bold text-slate-900 text-lg leading-tight">{officer.name}</p>
                <p class="text-teal-600 text-sm font-bold mt-1">{officer.role}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <h4 class="text-xl font-bold text-slate-800 border-b border-slate-200 pb-3 mb-8">Directors</h4>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {directors.map(director => (
            <div class="bg-slate-50 p-6 rounded-2xl border border-slate-100 flex items-center gap-5 hover:shadow-md transition-shadow">
              <div class="w-14 h-14 bg-slate-200 text-slate-600 rounded-full flex items-center justify-center font-bold text-xl shrink-0">{director.initials}</div>
              <div>
                <p class="font-bold text-slate-900 text-lg leading-tight">{director.name}</p>
                <p class="text-slate-500 text-sm font-medium mt-1">{director.role}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>
</Layout>