---
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <!-- Hero with Image Split -->
  <section class="max-w-7xl mx-auto py-24 px-6 grid lg:grid-cols-2 gap-16 items-center">
    <div>
      <h2 class="text-teal-600 font-bold tracking-widest uppercase text-sm mb-3">Join Our Team</h2>
      <h1 class="text-5xl font-extrabold text-slate-900 mb-6">Make a real difference in East Tampa.</h1>
      <p class="text-xl text-slate-600 leading-relaxed mb-8">
        Here's an opportunity to do something that will directly impact the community. We rely entirely on the generosity of volunteers to keep our clinic running.
      </p>
      <div class="flex gap-4">
        <a href="#roles" class="bg-slate-900 text-white font-bold px-8 py-3.5 rounded-full hover:bg-slate-800 transition-colors">View Open Roles</a>
      </div>
    </div>
    
    <div class="relative">
      <img 
        src="https://images.unsplash.com/photo-1584515979956-d9f6e5d09982?q=80&w=1600&auto=format&fit=crop" 
        alt="Medical professionals working together" 
        class="rounded-[2rem] shadow-2xl w-full h-[500px] object-cover"
      />
      <div class="absolute -bottom-6 -left-6 bg-white p-6 rounded-2xl shadow-xl border border-slate-100">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-teal-100 text-teal-600 rounded-full flex items-center justify-center font-bold text-xl">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
          </div>
          <div>
            <p class="font-bold text-slate-900">40+ Active</p>
            <p class="text-sm text-slate-500 font-medium">Volunteer Staff</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <section id="roles" class="bg-slate-50 py-24 px-6 border-t border-slate-200">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-8">
      <div class="bg-white p-10 rounded-3xl shadow-sm border border-slate-100 transition-all hover:-translate-y-1 hover:shadow-xl">
        <div class="w-14 h-14 bg-teal-50 text-teal-600 rounded-2xl flex items-center justify-center mb-6">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-4">Medical Professionals</h3>
        <p class="text-slate-600 mb-8 leading-relaxed">We are actively seeking volunteer certified physicians, physician assistants, nurse practitioners, nurses, and pharmacists to provide essential patient care.</p>
        <button class="w-full bg-slate-900 text-white font-bold py-3 rounded-xl hover:bg-slate-800 transition-colors">Apply as Medical Staff</button>
      </div>
      
      <div class="bg-white p-10 rounded-3xl shadow-sm border border-slate-100 transition-all hover:-translate-y-1 hover:shadow-xl">
         <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-6">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
        </div>
        <h3 class="text-2xl font-bold text-slate-900 mb-4">Administrative Staff</h3>
        <p class="text-slate-600 mb-8 leading-relaxed">Our clinic relies heavily on counselors, social workers, clerical staff, and administrative support personnel to keep operations running smoothly.</p>
        <button class="w-full bg-slate-900 text-white font-bold py-3 rounded-xl hover:bg-slate-800 transition-colors">Apply as Admin Staff</button>
      </div>
    </div>
  </section>
</Layout>