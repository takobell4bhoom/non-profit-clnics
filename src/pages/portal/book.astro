---
import Layout from '../../layouts/Layout.astro';
---
<Layout>
  <div class="bg-slate-50 min-h-screen py-12 px-6">
    <div class="max-w-4xl mx-auto">
      
      <div class="mb-10">
        <a href="/portal/dashboard" class="text-teal-600 font-bold text-sm flex items-center gap-2 mb-4 hover:text-teal-700">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Back to Dashboard
        </a>
        <h1 class="text-3xl font-extrabold text-slate-900">Schedule an Appointment</h1>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        
        <!-- Step 1: Select Provider -->
        <div class="bg-white p-8 rounded-3xl border border-slate-100 shadow-sm">
          <h2 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-3">
            <span class="w-8 h-8 bg-slate-900 text-white rounded-full flex items-center justify-center text-sm">1</span> 
            Select Provider
          </h2>
          
          <div class="space-y-4">
            <label class="flex items-center p-4 border-2 border-teal-500 bg-teal-50 rounded-2xl cursor-pointer">
              <input type="radio" name="provider" class="w-5 h-5 text-teal-600" checked>
              <div class="ml-4">
                <p class="font-bold text-slate-900">Dr. Antoinette Lloyd</p>
                <p class="text-sm text-slate-500">General Medicine</p>
              </div>
            </label>
            
            <label class="flex items-center p-4 border-2 border-slate-100 hover:border-slate-200 rounded-2xl cursor-pointer transition-colors">
              <input type="radio" name="provider" class="w-5 h-5 text-teal-600">
              <div class="ml-4">
                <p class="font-bold text-slate-900">Dr. Patrick Vincent</p>
                <p class="text-sm text-slate-500">Health Screenings</p>
              </div>
            </label>
          </div>
        </div>

        <!-- Step 2: Select Time -->
        <div class="bg-white p-8 rounded-3xl border border-slate-100 shadow-sm">
          <h2 class="text-lg font-bold text-slate-900 mb-6 flex items-center gap-3">
            <span class="w-8 h-8 bg-slate-900 text-white rounded-full flex items-center justify-center text-sm">2</span> 
            Available Times
          </h2>
          
          <p class="font-bold text-slate-700 mb-4">Tomorrow</p>
          <div class="grid grid-cols-2 gap-3 mb-8">
            <button class="py-3 border-2 border-slate-100 rounded-xl font-bold text-slate-600 hover:border-teal-500 hover:text-teal-600 transition-colors">12:30 PM</button>
            <button class="py-3 border-2 border-teal-500 bg-teal-50 rounded-xl font-bold text-teal-700">1:00 PM</button>
            <button class="py-3 border-2 border-slate-100 rounded-xl font-bold text-slate-600 hover:border-teal-500 hover:text-teal-600 transition-colors">2:15 PM</button>
            <button class="py-3 border-2 border-slate-100 rounded-xl font-bold text-slate-600 hover:border-teal-500 hover:text-teal-600 transition-colors">3:45 PM</button>
          </div>

          <button onclick="alert('Appointment successfully booked! (Demo)'); window.location.href='/portal/dashboard';" class="w-full bg-slate-900 hover:bg-slate-800 text-white font-bold text-lg py-4 rounded-xl shadow-md transition-all">
            Confirm Booking
          </button>
        </div>

      </div>
    </div>
  </div>
</Layout>