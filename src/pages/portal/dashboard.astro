---
import Layout from '../../layouts/Layout.astro';
---
<Layout>
  <div class="bg-slate-50 min-h-[80vh] py-12 px-6">
    <div class="max-w-5xl mx-auto">
      
      <div class="flex justify-between items-end mb-10 border-b border-slate-200 pb-6">
        <div>
          <h1 class="text-3xl font-extrabold text-slate-900">Welcome, John</h1>
          <p class="text-slate-600 mt-1">Manage your healthcare journey.</p>
        </div>
        <a href="/portal/book" class="bg-teal-600 hover:bg-teal-700 text-white font-bold px-6 py-3 rounded-full shadow-lg shadow-teal-600/20 transition-all">
          + New Appointment
        </a>
      </div>

      <div class="bg-white p-12 rounded-3xl border border-slate-100 shadow-sm text-center">
        <div class="w-20 h-20 bg-slate-50 text-slate-300 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
        </div>
        <h3 class="text-xl font-bold text-slate-900 mb-2">No Upcoming Appointments</h3>
        <p class="text-slate-500 mb-8 max-w-md mx-auto">You currently have no scheduled visits. Book an appointment to consult with our medical staff.</p>
        <a href="/portal/book" class="bg-slate-900 hover:bg-slate-800 text-white font-bold px-8 py-3.5 rounded-xl transition-all">
          Schedule a Visit
        </a>
      </div>

    </div>
  </div>
</Layout>