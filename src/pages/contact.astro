---
import Layout from '../layouts/Layout.astro';
---
<Layout>
  <section class="max-w-7xl mx-auto py-24 px-6">
    <div class="grid lg:grid-cols-2 gap-16">
      
      <!-- Contact Info Side -->
      <div>
        <h2 class="text-teal-600 font-bold tracking-widest uppercase text-sm mb-3">Get in Touch</h2>
        <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 mb-6 tracking-tight">We're here to help.</h1>
        <p class="text-lg text-slate-600 mb-12">Questions about our services or need to schedule a follow-up? Send us a message and our volunteer staff will get back to you shortly.</p>
        
        <div class="space-y-8">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-slate-100 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-slate-900">Our Location</h3>
              <p class="text-slate-600 mt-1">3401 E Louisiana Ave<br/>Tampa, FL 33610, USA</p>
            </div>
          </div>
          
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-slate-100 rounded-full flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            </div>
            <div>
              <h3 class="text-lg font-bold text-slate-900">Phone Support</h3>
              <p class="text-slate-600 mt-1">(813) 238-6000</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Premium Form Side -->
      <div class="bg-white p-8 md:p-12 rounded-3xl shadow-xl shadow-slate-200/40 border border-slate-100">
        <form class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-sm font-bold text-slate-700">First Name</label>
              <input type="text" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 rounded-xl focus:outline-none focus:ring-2 focus:ring-teal-500/50 focus:bg-white transition-all" placeholder="John" />
            </div>
            <div class="space-y-2">
              <label class="text-sm font-bold text-slate-700">Last Name</label>
              <input type="text" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 rounded-xl focus:outline-none focus:ring-2 focus:ring-teal-500/50 focus:bg-white transition-all" placeholder="Doe" />
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-sm font-bold text-slate-700">Email Address</label>
            <input type="email" class="w-full bg-slate-50 border border-slate-200 px-4 py-3 rounded-xl focus:outline-none focus:ring-2 focus:ring-teal-500/50 focus:bg-white transition-all" placeholder="john@example.com" />
          </div>
          <div class="space-y-2">
            <label class="text-sm font-bold text-slate-700">Message</label>
            <textarea class="w-full bg-slate-50 border border-slate-200 px-4 py-3 rounded-xl h-32 focus:outline-none focus:ring-2 focus:ring-teal-500/50 focus:bg-white transition-all resize-none" placeholder="How can we help you today?"></textarea>
          </div>
          <button type="button" class="w-full bg-slate-900 hover:bg-slate-800 text-white font-bold text-lg py-4 rounded-xl shadow-md transition-all hover:-translate-y-0.5 mt-4">
            Send Message
          </button>
        </form>
      </div>
      
    </div>
  </section>
</Layout>