---
import '../styles/global.css';
---
<html lang="en" class="scroll-smooth">
  <head>
    <title>Calvary Community Clinic | East Tampa's Free Clinic</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
  </head>
  <body class="bg-slate-50 text-slate-900 flex flex-col min-h-screen antialiased selection:bg-teal-500 selection:text-white relative">
    
    <header class="sticky top-0 z-50 bg-white/90 backdrop-blur-lg border-b border-slate-200/60 shadow-sm">
      <nav class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center relative">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-gradient-to-br from-teal-600 to-emerald-500 rounded-xl flex items-center justify-center shadow-lg shadow-teal-500/20">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path></svg>
          </div>
          <div>
            <h1 class="font-extrabold text-xl tracking-tight text-slate-900 leading-none">CALVARY</h1>
            <p class="text-[0.65rem] font-bold text-teal-600 tracking-widest uppercase mt-0.5">Community Clinic</p>
          </div>
        </div>
        
        <!-- Desktop Navigation -->
        <div class="hidden lg:flex space-x-6 font-semibold text-sm items-center text-slate-600">
          <a href="/" class="hover:text-teal-600 transition-colors">Home</a>
          <a href="/about" class="hover:text-teal-600 transition-colors">About</a>
          <a href="/services" class="hover:text-teal-600 transition-colors">Services</a>
          <a href="/volunteer" class="hover:text-teal-600 transition-colors">Volunteer</a>
          <a href="/donate" class="hover:text-teal-600 transition-colors">Donate</a>
          <a href="/contact" class="hover:text-teal-600 transition-colors">Contact</a>
          <a href="/portal" class="bg-slate-900 hover:bg-slate-800 text-white px-6 py-2.5 rounded-full shadow-md shadow-slate-900/10 transition-all hover:-translate-y-0.5 font-semibold ml-2 inline-block">
  Book Appointment
</a>
        </div>

        <!-- Mobile Menu Toggle Button -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 text-slate-600 hover:text-teal-600 focus:outline-none">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
      </nav>

      <!-- Mobile Dropdown Menu -->
      <div id="mobile-menu" class="hidden lg:hidden absolute top-full left-0 w-full bg-white border-b border-slate-200 shadow-xl flex flex-col font-semibold text-slate-700">
        <a href="/" class="px-6 py-4 border-b border-slate-100 hover:bg-slate-50 hover:text-teal-600">Home</a>
        <a href="/about" class="px-6 py-4 border-b border-slate-100 hover:bg-slate-50 hover:text-teal-600">About</a>
        <a href="/services" class="px-6 py-4 border-b border-slate-100 hover:bg-slate-50 hover:text-teal-600">Services</a>
        <a href="/volunteer" class="px-6 py-4 border-b border-slate-100 hover:bg-slate-50 hover:text-teal-600">Volunteer</a>
        <a href="/donate" class="px-6 py-4 border-b border-slate-100 hover:bg-slate-50 hover:text-teal-600">Donate</a>
        <a href="/contact" class="px-6 py-4 border-b border-slate-100 hover:bg-slate-50 hover:text-teal-600">Contact</a>
        <a href="/portal" class="bg-slate-900 hover:bg-slate-800 text-white px-6 py-2.5 rounded-full shadow-md shadow-slate-900/10 transition-all hover:-translate-y-0.5 font-semibold ml-2 inline-block">
  Book Appointment
</a>
      </div>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer remains unchanged -->
    <footer class="bg-slate-950 text-slate-400 py-16 border-t border-slate-800 mt-auto">
      <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-12">
        <div>
          <h2 class="text-white font-bold text-lg mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Calvary Clinic
          </h2>
          <p class="text-sm leading-relaxed mb-6">Providing free, quality, compassionate healthcare and health education services to the uninsured, underserved, and working poor of Hillsborough County.</p>
        </div>
        <div>
          <h3 class="text-white font-semibold mb-4">Contact Details</h3>
          <ul class="space-y-3 text-sm">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-slate-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
              <span>3401 E Louisiana Ave<br/>Tampa, FL 33610, USA</span>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-5 h-5 text-slate-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
              (813) 238-6000
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-white font-semibold mb-4">Quick Links</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/about" class="hover:text-white transition-colors">About Us</a></li>
            <li><a href="/services" class="hover:text-white transition-colors">Our Services</a></li>
            <li><a href="/volunteer" class="hover:text-white transition-colors">Volunteer</a></li>
            <li><a href="/donate" class="hover:text-white transition-colors">Donate</a></li>
          </ul>
        </div>
      </div>
      <div class="max-w-7xl mx-auto px-6 mt-12 pt-8 border-t border-slate-800 text-xs text-slate-500 flex flex-col md:flex-row justify-between items-center">
        <p>© 2026 Calvary Community Clinic. A registered non-profit organization.</p>
        <p class="mt-2 md:mt-0">Designed for East Tampa.</p>
      </div>
    </footer>

    <!-- Mobile Menu Script -->
    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      
      btn?.addEventListener('click', () => {
        menu?.classList.toggle('hidden');
      });
    </script>
  </body>
</html>